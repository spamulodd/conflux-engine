---
source: crates/conflux-backend/src/singbox/config.rs
expression: redacted
---
{
  "dns": {
    "servers": [
      {
        "address": "1.1.1.1",
        "tag": "dns-direct"
      }
    ]
  },
  "inbounds": [
    {
      "auto_route": true,
      "inet4_address": "172.19.0.1/30",
      "interface_name": "conflux-tun",
      "strict_route": true,
      "tag": "tun-in",
      "type": "tun"
    }
  ],
  "log": {
    "level": "info"
  },
  "outbounds": [
    {
      "method": "2022-blake3-aes-128-gcm",
      "password": "<REDACTED_PASSWORD>",
      "server": "<REDACTED_SERVER>",
      "server_port": 8388,
      "tag": "proxy",
      "type": "shadowsocks"
    },
    {
      "tag": "direct",
      "type": "direct"
    },
    {
      "tag": "dns-out",
      "type": "dns"
    }
  ],
  "route": {
    "final": "proxy",
    "rules": [
      {
        "outbound": "dns-out",
        "protocol": "dns"
      },
      {
        "inbound": "tun-in",
        "outbound": "proxy"
      }
    ]
  }
}
