---
source: crates/conflux-backend/src/singbox/config.rs
expression: redacted
---
{
  "dns": {
    "servers": [
      {
        "address": "1.1.1.1",
        "tag": "dns-direct"
      }
    ]
  },
  "inbounds": [
    {
      "listen": "127.0.0.1",
      "listen_port": 7890,
      "tag": "mixed-in",
      "type": "mixed"
    }
  ],
  "log": {
    "level": "info"
  },
  "outbounds": [
    {
      "alter_id": 0,
      "packet_encoding": "xudp",
      "security": "auto",
      "server": "<REDACTED_SERVER>",
      "server_port": 443,
      "tag": "proxy",
      "tls": {
        "enabled": true,
        "server_name": "<REDACTED_HOST>"
      },
      "transport": {
        "host": "<REDACTED_HOST>",
        "path": "/ws",
        "type": "ws"
      },
      "type": "vmess",
      "uuid": "<REDACTED_UUID>"
    },
    {
      "tag": "direct",
      "type": "direct"
    },
    {
      "tag": "dns-out",
      "type": "dns"
    }
  ],
  "route": {
    "final": "proxy",
    "rules": [
      {
        "outbound": "dns-out",
        "protocol": "dns"
      },
      {
        "inbound": "mixed-in",
        "outbound": "proxy"
      }
    ]
  }
}
