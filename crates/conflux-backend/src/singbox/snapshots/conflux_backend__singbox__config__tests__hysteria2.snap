{
  "inbounds": [
    {
      "listen": "127.0.0.1",
      "listen_port": 7890,
      "tag": "mixed-in",
      "type": "mixed"
    }
  ],
  "log": {
    "level": "info"
  },
  "outbounds": [
    {
      "obfs": {
        "password": "<REDACTED_PASSWORD>",
        "type": "salamander"
      },
      "password": "<REDACTED_PASSWORD>",
      "server": "<REDACTED_SERVER>",
      "server_port": 443,
      "server_ports": [
        "443-8443"
      ],
      "tag": "proxy",
      "tls": {
        "enabled": true,
        "server_name": "<REDACTED_HOST>"
      },
      "type": "hysteria2"
    },
    {
      "tag": "direct",
      "type": "direct"
    }
  ],
  "route": {
    "final": "proxy",
    "rules": [
      {
        "inbound": "mixed-in",
        "outbound": "proxy"
      }
    ]
  }
}
